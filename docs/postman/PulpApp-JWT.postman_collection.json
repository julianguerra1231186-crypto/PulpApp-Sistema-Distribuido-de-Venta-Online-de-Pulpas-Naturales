{
  "info": {
    "name": "PulpApp — JWT Auth",
    "description": "Colección para probar el sistema de autenticación JWT de PulpApp.\nBase URL: http://localhost:8090 (API Gateway)\n\nFlujo recomendado:\n1. Register → copia el token\n2. Pega el token en la variable {{jwt_token}}\n3. Prueba los endpoints protegidos",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8090",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string",
      "description": "Pega aquí el token recibido en login o register"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (SELLER)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cedula\": \"123456789\",\n  \"telefono\": \"3001234567\",\n  \"name\": \"Juan Vendedor\",\n  \"email\": \"seller@pulpapp.com\",\n  \"password\": \"seller123\",\n  \"direccion\": \"Calle 10 # 20-30\",\n  \"role\": \"ROLE_SELLER\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('jwt_token', res.token);",
                  "  console.log('Token guardado automáticamente');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register (ADMIN)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cedula\": \"987654321\",\n  \"telefono\": \"3009876543\",\n  \"name\": \"Ana Admin\",\n  \"email\": \"admin@pulpapp.com\",\n  \"password\": \"admin123\",\n  \"direccion\": \"Carrera 5 # 10-15\",\n  \"role\": \"ROLE_ADMIN\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('jwt_token', res.token);",
                  "  console.log('Token ADMIN guardado automáticamente');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@pulpapp.com\",\n  \"password\": \"admin123\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('jwt_token', res.token);",
                  "  console.log('Token guardado automáticamente');",
                  "}",
                  "pm.test('Login exitoso', () => pm.response.to.have.status(200));",
                  "pm.test('Token presente', () => pm.expect(res.token).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login — credenciales incorrectas (espera 401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@pulpapp.com\",\n  \"password\": \"wrongpassword\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Debe retornar 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "GET /products — autenticado (SELLER o ADMIN)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": "{{base_url}}/products"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /products — solo ADMIN",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": "{{base_url}}/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pulpa de Fresa\",\n  \"description\": \"Pulpa natural de fresa sin conservantes\",\n  \"price\": 8500,\n  \"stock\": 100,\n  \"available\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('ADMIN: Status 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /products — SELLER (espera 403)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": "{{base_url}}/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pulpa de Mora\",\n  \"description\": \"Pulpa natural de mora\",\n  \"price\": 7500,\n  \"stock\": 50,\n  \"available\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('SELLER no puede crear productos: 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /products — sin token (espera 401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/products"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Sin token: 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "POST /orders — SELLER puede crear pedido",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": "{{base_url}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"items\": [\n    { \"productId\": 1, \"cantidad\": 2 }\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /orders — ADMIN o SELLER",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": "{{base_url}}/orders"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET /users — solo ADMIN",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": "{{base_url}}/users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('ADMIN: Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /users — SELLER (espera 403)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": "{{base_url}}/users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('SELLER no puede ver usuarios: 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
